{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-unlisten",
    "core:window:default",
    "core:webview:default",
    "core:app:default",
    "opener:default",
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://www.divine-pride.net/**" },
        { "url": "https://divine-pride.net/**" },
        { "url": "https://ro.gnjoylatam.com/**" },
        { "url": "https://ragcalc.web.app/**" },
        { "url": "https://ragnarecap.web.app/**" },
        { "url": "https://github.com/**" }
      ]
    }
  ]
}
