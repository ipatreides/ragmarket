{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    // Emit the generated .js/.d.ts somewhere other than next to the
    // source — otherwise Vite picks up the compiled vite.config.js
    // and ignores edits to vite.config.ts.
    "outDir": ".tsbuild/node"
  },
  "include": ["vite.config.ts"]
}
